<script>
  // ── Scroll reveal ──
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.bc, .prob-item, .bsup-row').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = `opacity .5s ease ${(i % 5) * .06}s, transform .5s ease ${(i % 5) * .06}s`;
    obs.observe(el);
  });

  // ── Workflow tabs ──
  const stats = document.querySelectorAll('.wf-stat');
  const panels = document.querySelectorAll('.wf-panel-slide');

  let autoTimer = null;
  let currentStep = 0;

  function activateStep(idx) {
    currentStep = idx;
    stats.forEach((s, i) => s.classList.toggle('active', i === idx));
    panels.forEach((p, i) => p.classList.toggle('active', i === idx));
    spawnDots();
  }

  stats.forEach((s, i) => {
    s.addEventListener('click', () => {
      clearInterval(autoTimer);
      activateStep(i);
      startAuto();
    });
  });

  function startAuto() {
    autoTimer = setInterval(() => {
      activateStep((currentStep + 1) % 4);
    }, 4000);
  }
  startAuto();

  // ── Animated dots on panel ──
  const canvas = document.getElementById('wfCanvas');
  let dots = [];

  function resizeCanvas() {
    if (!canvas) return;
    const panel = canvas.parentElement;
    canvas.width  = panel.offsetWidth;
    canvas.height = panel.offsetHeight;
  }

  function spawnDots() {
    if (!canvas) return;
    resizeCanvas();
    const count = 18;
    dots = Array.from({ length: count }, () => ({
      x: Math.random() * canvas.width,
      y: canvas.height + 8,
      size: Math.random() * 3 + 1.5,
      speed: Math.random() * 1.2 + 0.5,
      opacity: Math.random() * 0.5 + 0.15,
      hue: Math.random() > 0.5 ? 0 : 1 // 0=accent, 1=light
    }));
  }

  function drawDots() {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    dots.forEach(d => {
      d.y -= d.speed;
      d.opacity -= 0.003;
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.size, 0, Math.PI * 2);
      ctx.fillStyle = d.hue === 0
        ? `rgba(151,76,255,${d.opacity})`
        : `rgba(192,132,252,${d.opacity})`;
      ctx.fill();
    });
    dots = dots.filter(d => d.opacity > 0 && d.y > -10);
    requestAnimationFrame(drawDots);
  }

  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();
  spawnDots();
  drawDots();
</script>
