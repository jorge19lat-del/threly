<script>

  // ── Scroll reveal ──
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.bc, .prob-item, .bsup-row').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = `opacity .5s ease ${(i % 5) * .06}s, transform .5s ease ${(i % 5) * .06}s`;
    obs.observe(el);
  });

  // ── Workflow tabs ──
  const stats = document.querySelectorAll('.wf-stat');
  const panels = document.querySelectorAll('.wf-panel-slide');

  let autoTimer = null;
  let currentStep = 0;

  function activateStep(idx) {
    currentStep = idx;
    stats.forEach((s, i) => s.classList.toggle('active', i === idx));
    panels.forEach((p, i) => p.classList.toggle('active', i === idx));
    spawnDots();
  }

  stats.forEach((s, i) => {
    s.addEventListener('click', () => {
      clearInterval(autoTimer);
      activateStep(i);
      startAuto();
    });
  });

  function startAuto() {
    autoTimer = setInterval(() => {
      activateStep((currentStep + 1) % 4);
    }, 4000);
  }
  startAuto();

  // ── Animated dots on panel ──
  const canvas = document.getElementById('wfCanvas');
  let dots = [];

  function resizeCanvas() {
    if (!canvas) return;
    const panel = canvas.parentElement;
    canvas.width  = panel.offsetWidth;
    canvas.height = panel.offsetHeight;
  }

  function spawnDots() {
    if (!canvas) return;
    resizeCanvas();
    const count = 18;
    dots = Array.from({ length: count }, () => ({
      x: Math.random() * canvas.width,
      y: canvas.height + 8,
      size: Math.random() * 3 + 1.5,
      speed: Math.random() * 1.2 + 0.5,
      opacity: Math.random() * 0.5 + 0.15,
      hue: Math.random() > 0.5 ? 0 : 1 // 0=accent, 1=light
    }));
  }

  function drawDots() {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    dots.forEach(d => {
      d.y -= d.speed;
      d.opacity -= 0.003;
      ctx.beginPath();
      ctx.arc(d.x, d.y, d.size, 0, Math.PI * 2);
      ctx.fillStyle = d.hue === 0
        ? `rgba(151,76,255,${d.opacity})`
        : `rgba(192,132,252,${d.opacity})`;
      ctx.fill();
    });
    dots = dots.filter(d => d.opacity > 0 && d.y > -10);
    requestAnimationFrame(drawDots);
  }

  window.addEventListener('resize', resizeCanvas);
  resizeCanvas();
  spawnDots();
  drawDots();



  const featureLabels = {
    home: '',
    campaigns: 'Campaign Management',
    tasks: 'Smart Task Management',
    suppliers: 'Supplier Collaboration',
    budget: 'Budget Intelligence',
    dam: 'Digital Asset Management',
    resources: 'Resource Allocation',
  };

  function showPage(pageId) {
    // Hide all pages
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    
    // Show/hide navs
    const homeNav = document.getElementById('home-nav');
    const subNav = document.getElementById('sub-nav');
    
    if (pageId === 'home') {
      homeNav.style.display = 'flex';
      subNav.style.display = 'none';
    } else {
      homeNav.style.display = 'none';
      subNav.style.display = 'flex';
      document.getElementById('sub-nav-label').textContent = featureLabels[pageId] || pageId;
    }
    
    // Show target page
    const target = document.getElementById('page-' + pageId);
    if (target) {
      target.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    
    // Re-init story for subpages
    initStory(pageId);
  }

  function initStory(pageId) {
    const page = document.getElementById('page-' + pageId);
    if (!page) return;
    const points = page.querySelectorAll('.story-point');
    const slides = page.querySelectorAll('.panel-slide');
    const tagEl = page.querySelector('#panelTag');
    
    if (!points.length) return;
    
    const tagMap = {
      campaigns: ['Brief builder','Timeline view','Campaign types','Team & suppliers'],
      tasks: ['Task cards','Conflict detection','Workload heatmap','Smart suggestions'],
      suppliers: ['Supplier profile','Brief & assign','Performance index','Alerts & renewals'],
      budget: ['Auto-generate','Live tracking','Smart suggestions','Historical intel'],
      dam: ['Channel rights','Territory view','Expiration alerts','Multi-supplier rights'],
      resources: ['Heatmap','Bottleneck detection','Redistribute','Capacity planning'],
    };
    const tags = tagMap[pageId] || [];
    
    function activate(idx) {
      points.forEach((p, i) => p.classList.toggle('active', i === idx));
      slides.forEach((s, i) => s.classList.toggle('active', i === idx));
      if (tagEl && tags[idx]) tagEl.textContent = tags[idx];
    }
    
    // Remove old listeners by cloning
    points.forEach((p, i) => {
      const clone = p.cloneNode(true);
      p.parentNode.replaceChild(clone, p);
    });
    
    // Re-query after clone
    const freshPoints = page.querySelectorAll('.story-point');
    freshPoints.forEach((p, i) => {
      p.addEventListener('click', () => activate(i));
    });
    
    activate(0);
    
    // Scroll-driven activation
    const story = page.querySelector('#story');
    if (story) {
      window.addEventListener('scroll', function handler() {
        if (!story.closest('.page.active')) { window.removeEventListener('scroll', handler); return; }
        const r = story.getBoundingClientRect();
        const progress = Math.max(0, Math.min(1, -r.top / (story.offsetHeight - window.innerHeight)));
        const idx = Math.min(freshPoints.length - 1, Math.floor(progress * freshPoints.length));
        activate(idx);
      });
    }
  }

</script>
