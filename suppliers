<script>
  const points=document.querySelectorAll('.story-point'),slides=document.querySelectorAll('.panel-slide'),tags=['Supplier profile','Brief & assign','Performance index','Alerts & renewals'];
  function activate(idx){points.forEach((p,i)=>p.classList.toggle('active',i===idx));slides.forEach((s,i)=>s.classList.toggle('active',i===idx));document.getElementById('panelTag').textContent=tags[idx];}
  points.forEach((p,i)=>p.addEventListener('click',()=>activate(i)));
  const story=document.getElementById('story');
  window.addEventListener('scroll',()=>{if(!story)return;const r=story.getBoundingClientRect();const progress=Math.max(0,Math.min(1,-r.top/(story.offsetHeight-window.innerHeight)));activate(Math.min(3,Math.floor(progress*4)));});
</script>
