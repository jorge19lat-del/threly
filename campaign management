<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Campaign Management — threly</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:          #F5F5F5;
    --bg-alt:      #EBEBEB;
    --bg-deep:     #E2E2E2;
    --bg-card:     #FFFFFF;
    --bg-card-2:   #F9F9F9;
    --ink:         #0B0B0C;
    --ink-2:       #2E2E2E;
    --ink-3:       #6B6B6B;
    --ink-4:       #9A9A9A;
    --border:      rgba(11,11,12,0.07);
    --border-mid:  rgba(11,11,12,0.13);
    --border-str:  rgba(11,11,12,0.18);
    --accent:      #974CFF;
    --accent-hover:#8240e8;
    --accent-glow: rgba(151,76,255,0.15);
    --accent-soft: rgba(151,76,255,0.07);
    --accent-mid:  rgba(151,76,255,0.16);
    --accent-light:#c084fc;
    --success:     #16A34A;
    --success-bg:  rgba(22,163,74,0.08);
    --warning:     #B45309;
    --warning-bg:  rgba(180,83,9,0.08);
    --danger:      #E07B39;
    --danger-bg:   rgba(224,123,57,0.10);
    --font: 'Plus Jakarta Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg); color: var(--ink);
    font-family: var(--font); font-size: 16px;
    line-height: 1.6; overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border-mid); border-radius: 4px; }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    height: 64px; padding: 0 48px;
    display: flex; align-items: center; justify-content: space-between;
    background: rgba(245,245,245,0.9); backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .nav-left { display: flex; align-items: center; gap: 32px; }
  .logo { font-size: 18px; font-weight: 700; color: var(--ink); text-decoration: none; letter-spacing: -0.3px; }
  .logo span { color: var(--accent); }
  .nav-back {
    display: flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--ink-3); text-decoration: none;
    transition: color .2s;
  }
  .nav-back:hover { color: var(--ink); }
  .nav-back::before { content: '←'; font-size: 14px; }
  .nav-feature {
    font-size: 13px; color: var(--ink-4);
    padding-left: 32px; border-left: 1px solid var(--border-mid);
  }
  .nav-feature span { color: var(--ink-2); font-weight: 500; }
  .btn-primary {
    padding: 8px 20px; background: var(--accent); border: none;
    border-radius: 6px; color: #fff; font-family: var(--font);
    font-size: 14px; font-weight: 500; cursor: pointer;
    text-decoration: none; transition: all .2s;
  }
  .btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); box-shadow: 0 6px 20px var(--accent-glow); }

  /* ── HERO ── */
  #hero {
    padding: 160px 48px 100px;
    text-align: center;
    max-width: 860px; margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 5px 14px;
    background: var(--accent-soft); border: 1px solid var(--accent-mid);
    border-radius: 100px; font-size: 11px; color: var(--accent);
    font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
    margin-bottom: 32px;
  }

  .hero-title {
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 700; line-height: 1.02;
    letter-spacing: -0.03em; color: var(--ink);
    margin-bottom: 24px;
  }
  .hero-title em { font-style: normal; color: var(--accent); }

  .hero-sub {
    font-size: 19px; color: var(--ink-3); font-weight: 300;
    line-height: 1.7; max-width: 580px; margin: 0 auto 40px;
  }

  .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-ghost {
    padding: 10px 24px; background: transparent;
    border: 1px solid var(--border-mid); border-radius: 6px;
    color: var(--ink-2); font-family: var(--font); font-size: 15px;
    cursor: pointer; text-decoration: none; transition: all .2s;
  }
  .btn-ghost:hover { background: var(--bg-alt); border-color: var(--border-str); }
  .btn-lg { padding: 12px 28px; font-size: 15px; }

  /* ── HERO MOCKUP — full width ── */
  .hero-mockup-wrap {
    padding: 0 48px 80px;
    max-width: 1200px; margin: 0 auto;
  }

  .browser-frame {
    background: var(--bg-card);
    border: 1px solid var(--border-str);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 32px 80px rgba(11,11,12,0.12), 0 4px 16px var(--accent-glow);
  }

  .browser-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 14px 20px;
    background: var(--bg-card-2); border-bottom: 1px solid var(--border);
  }
  .b-dot { width: 10px; height: 10px; border-radius: 50%; }
  .b-dot.r { background: #EF4444; }
  .b-dot.y { background: #F59E0B; }
  .b-dot.g { background: #22C55E; }
  .b-url {
    flex: 1; margin: 0 16px;
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 14px;
    font-size: 12px; color: var(--ink-4); text-align: center;
  }

  /* Full dashboard inside browser */
  .dashboard {
    display: grid; grid-template-columns: 220px 1fr;
    min-height: 480px;
  }

  .dash-sidebar {
    background: var(--bg-card-2); border-right: 1px solid var(--border);
    padding: 20px 16px;
  }
  .dash-sidebar-logo {
    font-size: 14px; font-weight: 700; color: var(--ink);
    margin-bottom: 24px; padding: 0 8px;
  }
  .dash-sidebar-logo span { color: var(--accent); }
  .dash-nav-section {
    font-size: 10px; text-transform: uppercase; letter-spacing: .08em;
    color: var(--ink-4); font-weight: 600; padding: 0 8px; margin-bottom: 6px;
  }
  .dash-nav-item {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 8px; border-radius: 6px;
    font-size: 13px; color: var(--ink-3); margin-bottom: 2px;
    cursor: pointer; transition: all .2s;
  }
  .dash-nav-item.active {
    background: var(--accent-soft); color: var(--accent);
    border: 1px solid var(--accent-mid); font-weight: 500;
  }
  .dash-nav-dot {
    width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0;
  }

  .dash-main { padding: 24px 28px; }

  .dash-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
  }
  .dash-title { font-size: 18px; font-weight: 700; color: var(--ink); }
  .dash-header-right { display: flex; gap: 8px; }
  .dash-pill {
    font-size: 11px; padding: 4px 12px; border-radius: 100px;
    border: 1px solid var(--border-mid); color: var(--ink-3);
    background: var(--bg-card); cursor: pointer;
  }
  .dash-pill.active {
    background: var(--accent-soft); color: var(--accent);
    border-color: var(--accent-mid); font-weight: 500;
  }

  .kanban { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }

  .kan-col-head {
    font-size: 11px; text-transform: uppercase; letter-spacing: .07em;
    color: var(--ink-4); font-weight: 600;
    padding-bottom: 10px; border-bottom: 1px solid var(--border);
    margin-bottom: 10px;
  }

  .kan-card {
    background: var(--bg-card); border: 1px solid var(--border-mid);
    border-radius: 10px; padding: 12px 14px; margin-bottom: 10px;
    transition: box-shadow .2s;
  }
  .kan-card:hover { box-shadow: 0 4px 16px rgba(11,11,12,.06); }
  .kan-card.active-card { border-color: var(--accent-mid); box-shadow: 0 0 0 3px var(--accent-soft); }

  .kan-tag {
    font-size: 10px; padding: 2px 8px; border-radius: 100px;
    font-weight: 600; display: inline-block; margin-bottom: 6px;
  }
  .kan-tag.editorial { background: var(--accent-soft); color: var(--accent); border: 1px solid var(--accent-mid); }
  .kan-tag.commercial { background: rgba(22,163,74,.08); color: #16A34A; }

  .kan-name { font-size: 13px; font-weight: 600; color: var(--ink); margin-bottom: 8px; }
  .kan-progress { height: 3px; background: var(--bg-alt); border-radius: 3px; overflow: hidden; margin-bottom: 8px; }
  .kan-progress-fill { height: 100%; background: var(--accent); border-radius: 3px; }
  .kan-meta { display: flex; justify-content: space-between; font-size: 10px; color: var(--ink-4); }

  /* ── STATS BAR ── */
  .stats-bar {
    display: flex; gap: 0;
    border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    background: var(--bg-card); margin: 0;
  }
  .stat-item {
    flex: 1; padding: 32px 48px;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  .stat-item:last-child { border-right: none; }
  .stat-num {
    font-size: 44px; font-weight: 800; color: var(--ink);
    letter-spacing: -0.03em; line-height: 1; margin-bottom: 6px;
  }
  .stat-num span { color: var(--accent); }
  .stat-label { font-size: 13px; color: var(--ink-3); font-weight: 400; }

  /* ── STICKY STORY SECTION ── */
  #story { padding: 120px 0; background: var(--bg-alt); }

  .story-inner {
    max-width: 1200px; margin: 0 auto; padding: 0 48px;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: start;
  }

  /* Left: scrolling story points */
  .story-points { display: flex; flex-direction: column; gap: 0; }

  .story-point {
    padding: 40px 0;
    border-bottom: 1px solid var(--border-mid);
    opacity: 0.35; transition: opacity .4s;
    cursor: pointer;
  }
  .story-point:first-child { border-top: 1px solid var(--border-mid); }
  .story-point.active { opacity: 1; }

  .sp-step {
    font-size: 11px; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 10px;
    opacity: 0; transition: opacity .3s;
  }
  .story-point.active .sp-step { opacity: 1; }

  .sp-title {
    font-size: 26px; font-weight: 700; color: var(--ink);
    letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 12px;
  }
  .sp-desc { font-size: 15px; color: var(--ink-3); line-height: 1.7; }

  .sp-bar {
    height: 2px; background: var(--accent);
    width: 0; margin-top: 24px; transition: width .5s ease;
    border-radius: 2px;
  }
  .story-point.active .sp-bar { width: 100%; }

  /* Right: sticky mockup panel */
  .story-panel-wrap {
    position: sticky; top: 100px;
  }

  .story-panel {
    background: var(--bg-card);
    border: 1px solid var(--border-mid);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 12px 48px rgba(11,11,12,.09);
    min-height: 400px; position: relative;
  }

  .story-panel-header {
    padding: 14px 20px;
    background: var(--bg-card-2); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 8px;
  }
  .sph-title { font-size: 12px; color: var(--ink-3); flex: 1; }
  .sph-tag {
    font-size: 10px; padding: 2px 8px; border-radius: 100px;
    background: var(--accent-soft); color: var(--accent);
    border: 1px solid var(--accent-mid); font-weight: 600;
  }

  .panel-slide {
    position: absolute; inset: 0; top: 49px;
    opacity: 0; transition: opacity .4s;
    padding: 24px 24px;
    pointer-events: none;
  }
  .panel-slide.active { opacity: 1; pointer-events: auto; }

  /* Panel 1 — Timeline view */
  .timeline-view { display: flex; flex-direction: column; gap: 8px; }
  .tl-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    background: var(--bg-card-2); border: 1px solid var(--border);
    border-radius: 8px;
  }
  .tl-row.highlighted { border-color: var(--accent-mid); background: var(--accent-soft); }
  .tl-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .tl-name { font-size: 13px; color: var(--ink); font-weight: 500; flex: 1; }
  .tl-dates { font-size: 11px; color: var(--ink-4); }
  .tl-bar-wrap { width: 120px; height: 6px; background: var(--bg-deep); border-radius: 3px; overflow: hidden; }
  .tl-bar-fill { height: 100%; background: var(--accent); border-radius: 3px; }

  /* Panel 2 — Calendar view */
  .cal-view {}
  .cal-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .cal-month { font-size: 14px; font-weight: 600; color: var(--ink); }
  .cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .cal-day-head { font-size: 10px; color: var(--ink-4); text-align: center; padding: 4px 0; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
  .cal-day {
    height: 36px; border-radius: 6px; display: flex;
    align-items: center; justify-content: center;
    font-size: 12px; color: var(--ink-3); position: relative;
  }
  .cal-day.has-event { font-weight: 600; color: var(--ink); }
  .cal-event {
    position: absolute; bottom: 3px; left: 4px; right: 4px;
    height: 3px; border-radius: 2px;
  }
  .cal-day.today { background: var(--accent-soft); color: var(--accent); font-weight: 700; }

  /* Panel 3 — Brief builder */
  .brief-view { display: flex; flex-direction: column; gap: 10px; }
  .brief-field {
    background: var(--bg-card-2); border: 1px solid var(--border);
    border-radius: 8px; padding: 12px 16px;
  }
  .brief-field.focus { border-color: var(--accent-mid); background: var(--accent-soft); }
  .bf-label { font-size: 10px; text-transform: uppercase; letter-spacing: .07em; color: var(--ink-4); font-weight: 600; margin-bottom: 4px; }
  .bf-val { font-size: 13px; color: var(--ink); font-weight: 500; }
  .bf-auto {
    margin-left: auto; font-size: 10px; padding: 2px 7px;
    border-radius: 100px; background: var(--accent-soft);
    color: var(--accent); border: 1px solid var(--accent-mid); font-weight: 600;
  }
  .bf-row { display: flex; align-items: center; gap: 8px; }

  /* Panel 4 — Team view */
  .team-view { display: flex; flex-direction: column; gap: 8px; }
  .team-row {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 14px;
    background: var(--bg-card-2); border: 1px solid var(--border);
    border-radius: 8px;
  }
  .t-avatar {
    width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--accent-light));
  }
  .t-avatar.ext { background: var(--bg-deep); color: var(--ink-3); font-size: 10px; border: 1px solid var(--border-mid); }
  .t-info { flex: 1; }
  .t-name { font-size: 12px; font-weight: 600; color: var(--ink); }
  .t-role { font-size: 11px; color: var(--ink-4); }
  .t-tasks { font-size: 11px; color: var(--ink-3); }
  .t-status {
    font-size: 10px; padding: 2px 8px; border-radius: 100px; font-weight: 600;
  }
  .t-status.ok  { background: var(--success-bg); color: var(--success); }
  .t-status.wt  { background: var(--warning-bg); color: var(--warning); }

  /* ── PROBLEM / SOLUTION ── */
  #before-after { padding: 120px 0; background: var(--bg); }

  .ba-inner { max-width: 1100px; margin: 0 auto; padding: 0 48px; }
  .ba-header { text-align: center; margin-bottom: 64px; }

  .section-lbl {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 11px; text-transform: uppercase; letter-spacing: .1em;
    color: var(--accent); font-weight: 600; margin-bottom: 16px;
  }
  .section-lbl::before { content: ''; width: 14px; height: 2px; background: var(--accent); border-radius: 2px; }

  .ba-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border-mid); border: 1px solid var(--border-mid); border-radius: 16px; overflow: hidden; }

  .ba-col { padding: 40px 44px; background: var(--bg-card); }
  .ba-col.after { background: var(--accent-soft); }

  .ba-col-head {
    display: flex; align-items: center; gap: 10px;
    padding-bottom: 24px; border-bottom: 1px solid var(--border-mid); margin-bottom: 24px;
  }
  .ba-dot { width: 8px; height: 8px; border-radius: 50%; }
  .ba-dot.err { background: var(--danger); }
  .ba-dot.ok  { background: var(--accent); }
  .ba-col-ttl { font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; }
  .ba-col-ttl.err { color: var(--danger); }
  .ba-col-ttl.ok  { color: var(--accent); }

  .ba-items { display: flex; flex-direction: column; gap: 0; }
  .ba-item {
    padding: 18px 0;
    border-bottom: 1px solid var(--border);
  }
  .ba-item:last-child { border-bottom: none; padding-bottom: 0; }
  .ba-item:first-child { padding-top: 0; }
  .ba-item-title { font-size: 15px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
  .ba-item-desc  { font-size: 13px; color: var(--ink-3); line-height: 1.5; }

  /* ── CTA ── */
  #cta {
    padding: 120px 48px; text-align: center;
    background: var(--bg-alt);
    position: relative; overflow: hidden;
  }
  #cta::before {
    content: ''; position: absolute; top: -80px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(151,76,255,.12), transparent 70%);
    pointer-events: none;
  }
  .cta-inner { max-width: 580px; margin: 0 auto; position: relative; z-index: 1; }
  .cta-title { font-size: clamp(38px, 4vw, 54px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.05; color: var(--ink); margin-bottom: 16px; }
  .cta-sub { font-size: 17px; color: var(--ink-3); margin-bottom: 36px; font-weight: 300; }
  .cta-actions { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .cta-note { margin-top: 14px; font-size: 12px; color: var(--ink-4); }

  /* ── FOOTER ── */
  footer { padding: 40px 48px; border-top: 1px solid var(--border); background: var(--bg); }
  .foot-in { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 24px; }
  .foot-logo { font-size: 16px; font-weight: 700; color: var(--ink); }
  .foot-logo span { color: var(--accent); }
  .foot-copy { font-size: 12px; color: var(--ink-4); }
  .foot-back { font-size: 13px; color: var(--ink-3); text-decoration: none; transition: color .2s; }
  .foot-back:hover { color: var(--ink); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
  .fu { opacity: 0; animation: fadeUp .6s ease forwards; }
  .d1 { animation-delay: .1s; } .d2 { animation-delay: .2s; } .d3 { animation-delay: .3s; }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-left">
    <a href="threly.html" class="logo">threly<span>.</span></a>
    <a href="threly.html" class="nav-back">All features</a>
    <span class="nav-feature">→ <span>Campaign Management</span></span>
  </div>
  <a href="#cta" class="btn-primary">Get early access →</a>
</nav>

<!-- HERO -->
<div id="hero" class="fu">
  <div class="hero-eyebrow">Campaign Management</div>
  <h1 class="hero-title">Every campaign.<br><em>One place.</em></h1>
  <p class="hero-sub">Stop managing productions across spreadsheets, chats and emails. threly gives your team a single source of truth from brief to go-live.</p>
  <div class="hero-actions">
    <a href="#cta" class="btn-primary btn-lg">Get early access →</a>
    <a href="#story" class="btn-ghost btn-lg">See how it works</a>
  </div>
</div>

<!-- HERO MOCKUP — full width browser frame -->
<div class="hero-mockup-wrap fu d2">
  <div class="browser-frame">
    <div class="browser-bar">
      <div class="b-dot r"></div>
      <div class="b-dot y"></div>
      <div class="b-dot g"></div>
      <div class="b-url">app.threly.io / campaigns</div>
    </div>
    <div class="dashboard">
      <!-- Sidebar -->
      <div class="dash-sidebar">
        <div class="dash-sidebar-logo">threly<span>.</span></div>
        <div class="dash-nav-section" style="margin-top:8px;">Campaigns</div>
        <div class="dash-nav-item active"><div class="dash-nav-dot"></div>All campaigns</div>
        <div class="dash-nav-item"><div class="dash-nav-dot"></div>Editorial</div>
        <div class="dash-nav-item"><div class="dash-nav-dot"></div>Commercial</div>
        <div class="dash-nav-item"><div class="dash-nav-dot"></div>Archive</div>
        <div class="dash-nav-section" style="margin-top:20px;">Workspace</div>
