<script>
  // Scroll reveal
  const revealObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll('.kan-card, .tl-row, .ba-item, .team-row').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(14px)';
    el.style.transition = `opacity .5s ease ${(i % 4) * .07}s, transform .5s ease ${(i % 4) * .07}s`;
    revealObs.observe(el);
  });

  // Sticky story — scroll-driven activation
  const points = document.querySelectorAll('.story-point');
  const slides = document.querySelectorAll('.panel-slide');
  const tags = ['Brief builder', 'Timeline view', 'Campaign types', 'Team & suppliers'];

  function activatePoint(idx) {
    points.forEach((p, i) => p.classList.toggle('active', i === idx));
    slides.forEach((s, i) => s.classList.toggle('active', i === idx));
    document.getElementById('panelTag').textContent = tags[idx];
  }

  // Click on story points
  points.forEach((p, i) => {
    p.addEventListener('click', () => activatePoint(i));
  });

  // Scroll-driven activation
  const storySection = document.getElementById('story');
  window.addEventListener('scroll', () => {
    if (!storySection) return;
    const rect = storySection.getBoundingClientRect();
    const sectionH = storySection.offsetHeight;
    const progress = Math.max(0, Math.min(1, -rect.top / (sectionH - window.innerHeight)));
    const idx = Math.min(3, Math.floor(progress * 4));
    activatePoint(idx);
  });
</script>
